# ============================================================
# Root .env — used by docker-compose only
# Copy to .env and set real values before deploying
# ============================================================

# MySQL (docker-compose defaults shown — change these!)
DB_ROOT_PASSWORD=change_me_root
DB_NAME=realestate_db
DB_USER=realestate
DB_PASSWORD=change_me_db

# Redis
REDIS_PASSWORD=change_me_redis

# ============================================================
# Per-service secrets live in each service's .env file:
#   services/auth-service/.env        — JWT, Twilio
#   services/notification-service/.env — Firebase
#   services/media-service/.env        — Cloudflare R2
# ============================================================
